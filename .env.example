OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
DEFAULT_MODEL=openai/gpt-4o-mini
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

OLLAMA_BASE_URL=
# Set to https://ollama.com/v1/ for Ollama Cloud
# Leave empty on Streamlit Cloud if not using Ollama

OLLAMA_API_KEY=
# Required for Ollama Cloud only. Get one at ollama.com/settings/keys
# Leave empty for local Ollama

ADZUNA_APP_ID=
ADZUNA_APP_KEY=
# Free keys at https://developer.adzuna.com/
# Both required to enable the Live Job Search sidebar toggle

# Optional: enables Mistral Moderation for multilingual injection detection
# Get a free key at https://console.mistral.ai/
# If not set, falls back to the LLM semantic check and phrase-list detection
MISTRAL_API_KEY=
